#!/usr/bin/env sh
set -eu

cd "$(git rev-parse --show-toplevel)"

if [ -x "venv/bin/ruff" ]; then
    RUFF="venv/bin/ruff"
else
    RUFF="ruff"
fi

if ! command -v "$RUFF" >/dev/null 2>&1; then
    echo "pre-commit: ruff is not installed, please install it (\`pip install ruff\` inside your venv)" >&2
    exit 1
fi

before_status="$(git status --porcelain)"
"$RUFF" format .
after_status="$(git status --porcelain)"

if [ "$before_status" != "$after_status" ]; then
    echo "pre-commit: ruff format changed files. Review and stage them, then commit again." >&2
    exit 1
fi
